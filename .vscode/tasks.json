{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "wrangler-dev-inspect",
      "type": "shell",
      "command": "npx wrangler dev --env dev --port 8789 --inspector-port 9229",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "wrangler",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready on|listening on|http://"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    }
  ]
}
