  "turns": [
    { "text": "hi" },
    { "text": "plantation in sakleshpur" },
    {
      "text": "give me details on the project",
      "assert": {
        "reply_includes": ["which"],
        "reply_excludes": ["possession December"]
      }
    },
    {
      "text": "Ayana",
      "assert": {
        "reply_includes": ["ayana"]
      }
    },
    {
      "text": "what plot sizes are offered?",
      "assert": {
        "reply_excludes": ["no *plot*", "closest fit", "on our books"]
      }
    },
    {
      "text": "are there any legal issues?",
      "assert": {
        "reply_excludes": ["i hear you"]
      }
    },
    { "text": "and the pricing details" },
    {
      "text": "ok lets do a site visit",
      "assert": {
        "reply_includes": ["day", "visit"],
        "reply_excludes": ["don't see a confirmed visit"]
      }
    },
    { "text": "saturday" }
  ]
}
