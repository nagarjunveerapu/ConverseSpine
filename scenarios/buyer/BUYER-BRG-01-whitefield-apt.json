      "assert": {
        "reply_excludes": ["tap a button"]
      }
    },
    {
      "text": "ok lets do a site visit",
      "assert": {
        "reply_includes": ["visit"],
        "reply_excludes": ["don't see a confirmed visit", "tap a button"]
      }
    }
